# ═══════════════════════════════════════════════════════════
# Sentinel-AI — Variables d'environnement
# ═══════════════════════════════════════════════════════════
# Copiez ce fichier en .env et remplissez vos vraies valeurs.
# cp .env.example .env
#
# ⚠️  Ne JAMAIS committer le fichier .env dans git !
# ═══════════════════════════════════════════════════════════

# ── SMTP (Alertes Email) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=security@example.com

# ── Ollama (optionnel) ───────────────────────────────────
OLLAMA_API_KEY=

# ── Surcharges de configuration ──────────────────────────
# SENTINEL_LLM_API_URL=http://192.168.1.50:11434
# SENTINEL_LLM_MODEL_NAME=gemma4
# SENTINEL_CAMERA_SOURCE=rtsp://192.168.1.10:554/stream
# SENTINEL_DASHBOARD_PORT=8080
# SENTINEL_LOG_LEVEL=DEBUG
