# ═══════════════════════════════════════════════════════════
# Sentinel-AI — Variables d'environnement
# ═══════════════════════════════════════════════════════════
# Copiez ce fichier en .env et remplissez vos vraies valeurs.
# cp .env.example .env
#
# ⚠️  Ne JAMAIS committer le fichier .env dans git !
# ═══════════════════════════════════════════════════════════

# ── SMTP (Alertes Email) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=security@example.com
SMTP_USE_TLS=true

# ── Ollama (optionnel) ───────────────────────────────────
OLLAMA_API_KEY=

# ── Telegram Notifications (Etape 9) ─────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── API externe securisee (Etape 9) ──────────────────────
SENTINEL_EXTERNAL_API_KEY=

# ── Surcharges de configuration ──────────────────────────
# SENTINEL_LLM_API_URL=http://192.168.1.50:11434
# SENTINEL_LLM_MODEL_NAME=gemma4
# SENTINEL_LLM_ANALYSIS_INTERVAL=10
# SENTINEL_LLM_MAX_RETRIES=1
# SENTINEL_LLM_MAX_TOKENS=160
# SENTINEL_LLM_NUM_CTX=4096
# SENTINEL_LLM_KEEP_ALIVE=30m
# SENTINEL_SCENE_NARRATION=true
# SENTINEL_DEBUG_SCENE_NARRATION=true
# SENTINEL_LLM_SNAPSHOT_QUALITY=70
# SENTINEL_TTS_PLAYBACK=true
# SENTINEL_TTS_WINDOWS_SAPI=true
# SENTINEL_DETECTION_CONFIDENCE=0.35
# SENTINEL_DETECTION_INPUT_SIZE=960
# SENTINEL_DETECTION_SKIP_FRAMES=1
# SENTINEL_CAMERA_SOURCE=rtsp://192.168.1.10:554/stream
# SENTINEL_DASHBOARD_PORT=8080
# SENTINEL_LOG_LEVEL=DEBUG


# Sentinel-AI local runtime environment
# Loaded manually in PowerShell before launch.

# LLM (local Ollama)
SENTINEL_LLM_API_URL=http://localhost:11434
SENTINEL_LLM_MODEL_NAME=gemma4:e4b
SENTINEL_LLM_TIMEOUT=45
SENTINEL_LLM_ANALYSIS_INTERVAL=10
SENTINEL_LLM_MAX_RETRIES=1
SENTINEL_LLM_MAX_TOKENS=160
SENTINEL_LLM_NUM_CTX=1024
SENTINEL_LLM_KEEP_ALIVE=30m
SENTINEL_SCENE_NARRATION=true
SENTINEL_DEBUG_SCENE_NARRATION=true
SENTINEL_LLM_SNAPSHOT_QUALITY=70
SENTINEL_TTS_PLAYBACK=true
SENTINEL_TTS_WINDOWS_SAPI=true

# Detection tuning (more objects)
SENTINEL_DETECTION_CONFIDENCE=0.35
SENTINEL_DETECTION_INPUT_SIZE=960
SENTINEL_DETECTION_SKIP_FRAMES=1

# Camera and runtime
SENTINEL_CAMERA_SOURCE=0
SENTINEL_LOG_LEVEL=INFO

# Dashboard
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=sentinel
DASHBOARD_RATE_LIMIT_ENABLED=true
DASHBOARD_RATE_LIMIT_PER_MIN=120

# Optional integrations (empty = disabled)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SENTINEL_EXTERNAL_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

